# .env.example — copy to .env and fill in secrets. Never commit .env.

# ── Database ─────────────────────────────────────────────
# Production/Docker uses Postgres. For quick local dev on Windows without
# Postgres, use the SQLite URL below instead.
DATABASE_URL=postgresql+asyncpg://axiom:axiom@localhost:5432/axiom
# DATABASE_URL=sqlite+aiosqlite:///./.axiom/axiom.db

# ── ChromaDB ─────────────────────────────────────────────
CHROMA_URL=http://localhost:8001

# ── Embedding (choose one provider) ──────────────────────
AXIOM_EMBED_PROVIDER=ollama          # ollama | openai | local
AXIOM_OLLAMA_URL=http://localhost:11434
AXIOM_OLLAMA_MODEL=nomic-embed-text
OPENAI_API_KEY=                       # only if AXIOM_EMBED_PROVIDER=openai

# ── Auth ─────────────────────────────────────────────────
# OFF by default: local single-user mode, no token needed (dashboard + extension
# just work). Set true for shared/team/networked servers to enforce OAuth/keys.
AXIOM_AUTH_REQUIRED=false
# Generate RS256 keys with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste PEM contents (with \n literals) or leave blank for HS256 dev mode.
AXIOM_JWT_PRIVATE_KEY=
AXIOM_JWT_PUBLIC_KEY=
AXIOM_JWT_DEV_SECRET=change-me-in-production   # used only when RS256 keys absent
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AXIOM_AUTH_PROVIDER=github            # github | local

# ── eBPF (Linux only; ignored on Windows/macOS) ──────────
AXIOM_EBPF_ENABLED=true

# ── Deployment ───────────────────────────────────────────
AXIOM_BASE_URL=http://localhost:8000
AXIOM_FRONTEND_URL=http://localhost:3000
AXIOM_LOG_LEVEL=INFO
AXIOM_AIR_GAPPED=false
