{
  "name": "axiom-intelligence",
  "displayName": "AXIOM Code Intelligence",
  "description": "Inline failure-risk scoring and blast-radius prediction powered by AXIOM",
  "version": "1.0.0",
  "publisher": "axiom",
  "repository": { "type": "git", "url": "https://github.com/PRATHVI9607/AXIOM" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Machine Learning", "Other"],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:go",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "axiom",
          "title": "AXIOM",
          "icon": "media/scepter.svg"
        }
      ]
    },
    "views": {
      "axiom": [
        {
          "id": "axiom.riskView",
          "name": "Workspace Risk",
          "type": "webview"
        }
      ]
    },
    "commands": [
      { "command": "axiom.scanWorkspace", "title": "AXIOM: Scan Workspace", "icon": "$(search)" },
      { "command": "axiom.analyzeFile", "title": "AXIOM: Analyze Current File" },
      { "command": "axiom.analyzeWorkspace", "title": "AXIOM: Analyze Workspace" },
      { "command": "axiom.openDashboard", "title": "AXIOM: Open Dashboard" },
      { "command": "axiom.showBlastRadius", "title": "AXIOM: Show Blast Radius for Function" },
      { "command": "axiom.setToken", "title": "AXIOM: Set API Token" },
      { "command": "axiom.setProject", "title": "AXIOM: Set Project Id" }
    ],
    "menus": {
      "view/title": [
        { "command": "axiom.scanWorkspace", "when": "view == axiom.riskView", "group": "navigation" }
      ]
    },
    "configuration": {
      "title": "AXIOM",
      "properties": {
        "axiom.serverUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "AXIOM backend URL. Point at a hosted server to skip the local backend (set a token via 'AXIOM: Set API Token')."
        },
        "axiom.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "If the backend at serverUrl is down, auto-start `axiom serve` locally."
        },
        "axiom.backendCommand": {
          "type": "string",
          "default": "",
          "description": "Override the command used to start the backend (e.g. a PyInstaller binary path). Defaults to `axiom serve`."
        },
        "axiom.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to a Python interpreter that has `axiom` installed (used to run `python -m axiom.cli serve`). Leave blank to auto-detect a workspace .venv or a global `axiom`."
        },
        "axiom.embedProvider": {
          "type": "string",
          "enum": ["local", "ollama", "openai"],
          "default": "local",
          "description": "Embedding provider passed to an auto-started backend."
        },
        "axiom.projectId": { "type": "string", "default": "default" },
        "axiom.riskThreshold.warning": { "type": "number", "default": 0.5 },
        "axiom.riskThreshold.error": { "type": "number", "default": 0.8 },
        "axiom.autoAnalyzeOnSave": { "type": "boolean", "default": true }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.3"
  }
}
